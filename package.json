{
  "name": "@bergthorsten/bfh",
  "version": "0.1.0",
  "private": true,
  "description": "Pi extension: Jira ticket → verified PR harness (/bfh)",
  "keywords": ["pi-package"],
  "pi": {
    "extensions": ["./extensions/lean_bfh"]
  },
  "scripts": {
    "test": "bun test extensions/lean_bfh/__tests__",
    "selftest": "bun extensions/lean_bfh/run-selftest.ts",
    "validate:schema": "bun extensions/lean_bfh/validate-schema.ts",
    "check": "bun run test && bun run selftest && bun run validate:schema"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "pi-subagents": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "pi-subagents": {
      "optional": true
    }
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
