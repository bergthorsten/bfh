{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BFH Harness Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "jira": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseUrl": { "type": "string", "format": "uri" },
        "token": { "type": "string" },
        "authMode": { "type": "string", "enum": ["bearer", "basic"] },
        "email": { "type": "string" },
        "acceptanceFields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "constraintFields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultDifficulty": { "type": "integer", "enum": [1, 2, 3] },
        "baseBranch": { "type": "string", "minLength": 1 },
        "verifyRevisionLimit": { "type": "integer", "minimum": 0 },
        "designReviewRevisionLimit": { "type": "integer", "minimum": 0 },
        "externalPrRevisionLimit": { "type": "integer", "minimum": 0 },
        "maxReviewTouchedFiles": { "type": "integer", "minimum": 1 }
      }
    },
    "models": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "implement": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "1": { "type": "string" },
            "2": { "type": "string" },
            "3": { "type": "string" }
          }
        },
        "scout": { "type": "string" },
        "reviewer": { "type": "string" },
        "closer": { "type": "string" },
        "retro": { "type": "string" }
      }
    },
    "notifications": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "sound": { "type": "boolean" },
        "osNotify": { "type": "boolean" }
      }
    }
  }
}
