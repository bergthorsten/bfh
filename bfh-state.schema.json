{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BFH State",
  "type": "object",
  "required": [
    "schemaVersion",
    "ticketKey",
    "summary",
    "description",
    "linkedTickets",
    "labels",
    "acceptanceCriteria",
    "constraints",
    "currentStep",
    "difficulty",
    "git",
    "designReview",
    "human",
    "openQuestions",
    "scout",
    "implementationPlan",
    "revisionCount",
    "revisionLimit",
    "humanRevisionCount",
    "evidence",
    "review",
    "pr",
    "finalVerdict",
    "retroNotes",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "ticketKey": { "type": "string", "pattern": "^[A-Z][A-Z0-9]+-[0-9]+$" },
    "summary": { "type": "string" },
    "description": { "type": "string" },
    "linkedTickets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "type"],
        "properties": {
          "key": { "type": "string" },
          "type": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "labels": { "type": "array", "items": { "type": "string" } },
    "acceptanceCriteria": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "currentStep": {
      "type": "string",
      "enum": ["intake", "scout", "clarify", "implement", "verify_review", "close", "pr_review", "retro", "done", "failed"]
    },
    "difficulty": { "type": "integer", "enum": [1, 2, 3] },
    "git": {
      "type": "object",
      "required": ["branch", "baseBranch", "entryMode"],
      "properties": {
        "branch": { "type": "string", "minLength": 1 },
        "baseBranch": { "type": "string", "minLength": 1 },
        "entryMode": {
          "type": "string",
          "enum": ["greenfield", "adopt-continue", "adopt-verify", "adopt-fix", "resume"]
        }
      },
      "additionalProperties": false
    },
    "implementModelHint": { "type": "string" },
    "designReview": {
      "type": "object",
      "required": ["status", "options", "revisionCount", "revisionLimit"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_applicable", "awaiting_options", "awaiting_choice", "awaiting_proposal", "awaiting_approval", "approved"]
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "angle", "summary", "risks", "mitigations"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "angle": { "type": "string" },
              "summary": { "type": "string" },
              "risks": { "type": "array", "items": { "type": "string" } },
              "mitigations": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "selectedOptionId": { "type": "string" },
        "humanSteering": { "type": "string" },
        "proposal": { "type": "string" },
        "lastDeclineComment": { "type": "string" },
        "revisionCount": { "type": "integer", "minimum": 0 },
        "revisionLimit": { "type": "integer", "minimum": 0 },
        "decidedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "human": {
      "type": "object",
      "required": ["preImplement", "preClose", "postReview"],
      "properties": {
        "preImplement": {
          "type": "object",
          "required": ["required", "status"],
          "properties": {
            "required": { "type": "boolean" },
            "status": { "type": "string", "enum": ["not_needed", "pending", "approved"] },
            "comment": { "type": "string" },
            "requestedAt": { "type": "string", "format": "date-time" },
            "decidedAt": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        },
        "preClose": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": { "type": "string", "enum": ["pending", "approved", "changes_requested"] },
            "comment": { "type": "string" },
            "requestedAt": { "type": "string", "format": "date-time" },
            "decidedAt": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        },
        "postReview": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["not_needed", "pending", "approved_advisories", "fix_requested"]
            },
            "comment": { "type": "string" },
            "requestedAt": { "type": "string", "format": "date-time" },
            "decidedAt": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question"],
        "properties": {
          "id": { "type": "string" },
          "question": { "type": "string" },
          "answer": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "scout": {
      "type": "object",
      "required": ["relevantFiles", "patterns", "commands", "constraints", "summary"],
      "properties": {
        "relevantFiles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "reason"],
            "properties": {
              "path": { "type": "string" },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "patterns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name": { "type": "string" },
              "file": { "type": "string" },
              "description": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "commands": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "implementationPlan": { "type": "array", "items": { "type": "string" } },
    "revisionCount": { "type": "integer", "minimum": 0 },
    "revisionLimit": { "type": "integer", "minimum": 0 },
    "humanRevisionCount": { "type": "integer", "minimum": 0 },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "summary", "createdAt"],
        "properties": {
          "type": { "type": "string", "enum": ["test", "manual", "review", "pr", "note"] },
          "command": { "type": "string" },
          "passed": { "type": "boolean" },
          "summary": { "type": "string" },
          "logPath": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "review": {
      "type": "object",
      "required": ["verdict", "findings", "summary", "counts"],
      "properties": {
        "verdict": { "type": "string", "enum": ["pending", "approved", "needs_revision", "failed"] },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["severity", "category", "message"],
            "properties": {
              "severity": { "type": "string", "enum": ["critical", "warning", "info"] },
              "category": { "type": "string" },
              "message": { "type": "string" },
              "file": { "type": "string" },
              "line": { "type": "integer", "minimum": 1 },
              "principleRef": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "summary": { "type": "string" },
        "counts": {
          "type": "object",
          "required": ["critical", "warning", "info"],
          "properties": {
            "critical": { "type": "integer", "minimum": 0 },
            "warning": { "type": "integer", "minimum": 0 },
            "info": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "rubric": {
          "type": "object",
          "required": ["role", "categories"],
          "properties": {
            "role": { "const": "reviewer" },
            "categories": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["category", "verdict", "detail"],
                "properties": {
                  "category": { "type": "string" },
                  "verdict": { "type": "string" },
                  "detail": { "type": "string" }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "allowCloseDespiteCritical": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "pr": {
      "type": "object",
      "required": ["url", "draft"],
      "properties": {
        "url": { "type": ["string", "null"] },
        "draft": { "type": "boolean" },
        "reviewDecision": {
          "type": ["string", "null"],
          "enum": ["APPROVED", "CHANGES_REQUESTED", "REVIEW_REQUIRED", "COMMENTED", "PENDING", "DISMISSED", "UNKNOWN", null]
        },
        "unresolvedThreads": { "type": "integer", "minimum": 0 },
        "lastSyncedAt": { "type": ["string", "null"] },
        "checksPending": { "type": "integer", "minimum": 0 },
        "checksFailing": { "type": "integer", "minimum": 0 },
        "lastChecksSyncedAt": { "type": ["string", "null"] },
        "externalRevisionCount": { "type": "integer", "minimum": 0 },
        "externalRevisionLimit": { "type": "integer", "minimum": 0 },
        "allowDoneWithoutPrApproval": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "finalVerdict": { "type": "string", "enum": ["pending", "success", "failed"] },
    "retroNotes": { "type": "array", "items": { "type": "string" } },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
